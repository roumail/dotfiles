alias pp import rich; rich.print(%1)
alias yank import subprocess; subprocess.run('win32yank.exe -i --crlf', input=str(%1).encode(), check=True, shell=True)
alias dir import rich; rich.print([x for x in dir(%1) if not x.startswith('__')])
alias quit exit()
