[user]
	name = Rohail Taimour
	email = rohail.taimour@gmail.com
[core]
	autocrlf = input
	editor = vim
	pager = delta
	excludesfile = ~/.gitignore
[alias]
    # while on main/master update
    pm = pull origin master
    pn = pull origin main

    sn = fetch origin main:main
    sm = fetch origin master:master
    # delete branches that have been merged
    po = remote prune origin
    #push current branch to origin
    poh = "!f() { git push origin HEAD \"$@\"; }; f"
    ci = !git commit -m 'ci: empty commit' --no-verify --allow-empty && git push && git reset --soft HEAD~ && git push --force-with-lease
    # Fetch origin
    f = "!git fetch origin"

    # merge from origin directly
    mom = merge origin/master
    mon = merge origin/main

    # rebase from origin directly
    rom = rebase origin/master
    ron = rebase origin/main

    # switch to existing branch
    sw = switch

    # create and switch
    swc = switch -c
	ll="!git log --graph --format='%C(yellow)%h%C(red)%d%C(reset) - %C(bold green)(%ar)%C(reset) %s %C(blue)<%an>%C(reset)'"


[rerere]
	enabled = true
	autoUpdate = true
[branch]
	sort = -committerdate
[credential]
	helper = store

[interactive]
		diffFilter = delta --color-only

[delta]
		navigate = true    # use n and N to move between diff sections

		# delta detects terminal colors automatically; set one of these to disable auto-detection
		# dark = true
		#light = true
[merge]
		conflictstyle = diff3
[diff]
		colorMoved = default
	    tool = vimdiff
