#!/usr/bin/env bash
# Local environment variables (NOT in git)
# Copy to env.sh and customize for your machine

# Machine-specific paths
# export PATH="/opt/company/internal-tool:$PATH"

# Secrets and tokens
# export AWS_ACCESS_KEY_ID="..."
# export API_TOKEN="..."

# https://docs.astral.sh/uv/concepts/indexes/#package-indexes
# https://docs.astral.sh/uv/concepts/indexes/#searching-across-multiple-indexes
# https://docs.astral.sh/uv/reference/environment/#uv_index_strategy
# # uv / private package index auth
# Index name "artifactory" -> UV_INDEX_ARTIFACTORY_USERNAME / PASSWORD
# export UV_INDEX_ARTIFACTORY_USERNAME="user@engie.com"
# export UV_INDEX_ARTIFACTORY_PASSWORD="your-token-here"
# export UV_DEFAULT_INDEX="https://pypi.org/simple"
# used instead of --index-url
# instead of --extra-index-url, UV has UV_EXTRA_INDEX_URL, deprecated in favour of UV_INDEX
# export UV_INDEX="https://my-other-pypi.org/simple"
# export UV_INDEX_STRATEGY="unsafe-best-match"
